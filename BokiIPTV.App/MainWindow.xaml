<Window x:Class="BokiIPTV.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
        Title="BokiIPTV" Height="760" Width="1200"
        WindowStartupLocation="CenterScreen" Background="#202225">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="170"/>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Nav -->
        <ListBox Grid.Column="0" ItemsSource="{Binding Sections}" SelectedItem="{Binding SelectedSection}"
                 DisplayMemberPath="Title" Background="#1E1F22" Foreground="White"
                 BorderThickness="0" FontSize="14"/>

        <!-- Categories -->
        <DockPanel Grid.Column="1" Background="#2B2D31">
            <TextBlock DockPanel.Dock="Top" Text="Categories" Foreground="#B9BBBE"
                       Margin="10,8" FontWeight="SemiBold"/>
            <ListBox ItemsSource="{Binding SelectedSection.Categories}"
                     SelectedItem="{Binding SelectedSection.SelectedCategory}"
                     DisplayMemberPath="CategoryName" Background="Transparent" Foreground="White"
                     BorderThickness="0"
                     VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling"/>
        </DockPanel>

        <!-- Items + player -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="300"/>
            </Grid.RowDefinitions>

            <TextBox Grid.Row="0" Margin="8" Padding="6"
                     Text="{Binding SelectedSection.SearchText, UpdateSourceTrigger=PropertyChanged, Delay=400}"/>

            <ListBox Grid.Row="1" x:Name="ItemsList" ItemsSource="{Binding SelectedSection.Items}"
                     Background="#313338" Foreground="White" BorderThickness="0"
                     VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling"
                     ScrollViewer.IsDeferredScrollingEnabled="True">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <EventSetter Event="MouseDoubleClick" Handler="Item_DoubleClick"/>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Name}" Padding="4,3"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Grid Grid.Row="2" Background="Black">
                <vlc:VideoView x:Name="Video"/>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" HorizontalAlignment="Center"
                            Margin="0,0,0,8" Background="#88000000">
                    <Button Content="Play/Pause" Command="{Binding Player.PlayPauseCommand}" Margin="4" Padding="8,4"/>
                    <Button Content="Stop" Command="{Binding Player.StopCommand}" Margin="4" Padding="8,4"/>
                    <Slider Width="120" Minimum="0" Maximum="1" Value="{Binding Player.Volume}"
                            VerticalAlignment="Center" Margin="8,0"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>
