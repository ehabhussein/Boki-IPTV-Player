<Application x:Class="BokiIPTV.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:BokiIPTV.App"
             xmlns:m="clr-namespace:BokiIPTV.Core.Models;assembly=BokiIPTV.Core"
             xmlns:svc="clr-namespace:BokiIPTV.Core.Services;assembly=BokiIPTV.Core">
    <Application.Resources>

        <!-- ===== Palette ===== -->
        <Color x:Key="BgColor">#0E1015</Color>
        <SolidColorBrush x:Key="Bg" Color="#0E1015"/>
        <SolidColorBrush x:Key="Panel" Color="#15181F"/>
        <SolidColorBrush x:Key="Panel2" Color="#1B1F28"/>
        <SolidColorBrush x:Key="Card" Color="#1E2330"/>
        <SolidColorBrush x:Key="CardHover" Color="#28304180"/>
        <SolidColorBrush x:Key="Accent" Color="#6C7BFF"/>
        <SolidColorBrush x:Key="AccentDim" Color="#3A3F66"/>
        <SolidColorBrush x:Key="Text" Color="#E7E9EE"/>
        <SolidColorBrush x:Key="TextMuted" Color="#9AA0AE"/>

        <!-- ===== Buttons ===== -->
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
            <Setter Property="Background" Value="{StaticResource Accent}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Opacity" Value="0.88"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="b" Property="Background" Value="{StaticResource AccentDim}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ToggleButton">
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
            <Setter Property="Background" Value="{StaticResource Card}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="8"
                                BorderThickness="1" BorderBrush="{StaticResource AccentDim}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{StaticResource Accent}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="BorderBrush" Value="{StaticResource Accent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== TextBox (search) ===== -->
        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
            <Setter Property="CaretBrush" Value="{StaticResource Text}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{StaticResource Panel2}" CornerRadius="8" Padding="8,6">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== Nav list (sections) ===== -->
        <Style x:Key="NavList" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
                        <Setter Property="FontSize" Value="14"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="b" Padding="16,12" Margin="6,2" CornerRadius="8"
                                            Background="Transparent">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="b" Property="Background" Value="{StaticResource Panel2}"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="b" Property="Background" Value="{StaticResource Accent}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        </Style>
                    </Setter.Value>
                </Setter>
        </Style>

        <!-- ===== Category list ===== -->
        <Style x:Key="CategoryList" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="b" Padding="12,8" Margin="6,1" CornerRadius="6"
                                            Background="Transparent">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="b" Property="Background" Value="{StaticResource Card}"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="b" Property="Background" Value="{StaticResource Card}"/>
                                            <Setter Property="Foreground" Value="{StaticResource Text}"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        </Style>
                    </Setter.Value>
                </Setter>
        </Style>

        <!-- ===== Poster grid (items) ===== -->
        <Style x:Key="PosterGrid" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ItemsPanel">
                <Setter.Value>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="b" Margin="6" Padding="6" CornerRadius="10"
                                            Background="Transparent" BorderThickness="2" BorderBrush="Transparent">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="b" Property="Background" Value="{StaticResource Card}"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="b" Property="Background" Value="{StaticResource Card}"/>
                                            <Setter TargetName="b" Property="BorderBrush" Value="{StaticResource Accent}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        </Style>
                    </Setter.Value>
                </Setter>
        </Style>

        <!-- ===== Poster card templates (auto-selected by item type) ===== -->
        <DataTemplate DataType="{x:Type m:Movie}">
            <StackPanel Width="138">
                <Border Height="196" CornerRadius="8" Background="#0B0D12" ClipToBounds="True">
                    <Image Source="{Binding StreamIcon, Converter={x:Static local:PosterConverter.Instance}}"
                           Stretch="UniformToFill"/>
                </Border>
                <TextBlock Text="{Binding Name}" Foreground="{StaticResource Text}" FontSize="12"
                           Margin="2,6,2,0" TextWrapping="Wrap" MaxHeight="32" TextTrimming="CharacterEllipsis"/>
            </StackPanel>
        </DataTemplate>

        <DataTemplate DataType="{x:Type m:Series}">
            <StackPanel Width="138">
                <Border Height="196" CornerRadius="8" Background="#0B0D12" ClipToBounds="True">
                    <Image Source="{Binding Cover, Converter={x:Static local:PosterConverter.Instance}}"
                           Stretch="UniformToFill"/>
                </Border>
                <TextBlock Text="{Binding Name}" Foreground="{StaticResource Text}" FontSize="12"
                           Margin="2,6,2,0" TextWrapping="Wrap" MaxHeight="32" TextTrimming="CharacterEllipsis"/>
            </StackPanel>
        </DataTemplate>

        <DataTemplate DataType="{x:Type m:Channel}">
            <StackPanel Width="138">
                <Border Height="104" CornerRadius="8" Background="#0B0D12">
                    <Image Source="{Binding StreamIcon, Converter={x:Static local:PosterConverter.Instance}}"
                           Stretch="Uniform" Margin="14"/>
                </Border>
                <TextBlock Text="{Binding Name}" Foreground="{StaticResource Text}" FontSize="12"
                           Margin="2,6,2,0" TextWrapping="Wrap" MaxHeight="32" TextTrimming="CharacterEllipsis"/>
            </StackPanel>
        </DataTemplate>

        <DataTemplate DataType="{x:Type svc:FavoriteEntry}">
            <StackPanel Width="138">
                <Border Height="150" CornerRadius="8" Background="#0B0D12" ClipToBounds="True">
                    <Image Source="{Binding Icon, Converter={x:Static local:PosterConverter.Instance}}"
                           Stretch="UniformToFill"/>
                </Border>
                <TextBlock Text="{Binding Title}" Foreground="{StaticResource Text}" FontSize="12"
                           Margin="2,6,2,0" TextWrapping="Wrap" MaxHeight="32" TextTrimming="CharacterEllipsis"/>
            </StackPanel>
        </DataTemplate>

    </Application.Resources>
</Application>
